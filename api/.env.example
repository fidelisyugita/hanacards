# Server
PORT=3001
NODE_ENV=development

# PostgreSQL - replace with your actual connection string
# Railway: postgresql://postgres:password@host:port/railway
# Supabase: postgresql://postgres:password@host:port/postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/hanacards?schema=public"

# Firebase Admin SDK
# Download from Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# CORS - frontend URL
CORS_ORIGIN="http://localhost:5173"
